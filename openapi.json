              {
                "type": "null"
              }
            ],
            "title": "Vacancy Rate"
          },
          "expenses": {
            "$ref": "#/components/schemas/OperatingExpensesInput"
          },
          "debt_terms": {
            "$ref": "#/components/schemas/DebtTermsInput"
